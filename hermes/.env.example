# swstack × hermes-agent 환경변수 예시
# 복사하여 사용: cp hermes/.env.example hermes/.env
# 주의: hermes/.env 파일은 절대 git에 올리지 않습니다 (.gitignore에 포함됨)

# =============================================================================
# LLM API 키 — 하나 이상 설정 (우선순위: OpenRouter → Groq → Gemini)
# =============================================================================

# OpenRouter (무료 모델 25개+ 포함)
# 발급: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key-here

# Groq (무료 티어, 초고속)
# 발급: https://console.groq.com/keys
# GROQ_API_KEY=your-groq-key-here

# Google AI Studio (Gemini, 무료 티어)
# 발급: https://aistudio.google.com/apikey
# GOOGLE_API_KEY=your-google-api-key-here

# =============================================================================
# 게이트웨이 (선택 사항)
# =============================================================================

# Discord 봇 토큰 (Discord 게이트웨이 사용 시)
# 발급: https://discord.com/developers/applications
# DISCORD_TOKEN=your-discord-bot-token-here

# Slack 봇 토큰 (Slack 게이트웨이 사용 시)
# 발급: https://api.slack.com/apps
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_APP_TOKEN=xapp-your-slack-app-token
